<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-add-image-public-id-to-player-and-coach" author="dino">
        <addColumn tableName="players">
            <column name="image_public_id" type="VARCHAR(255)" remarks="Cloudinary public_id za sliku igraca"/>
        </addColumn>
        <addColumn tableName="coaches">
            <column name="image_public_id" type="VARCHAR(255)" remarks="Cloudinary public_id za sliku trenera"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>

